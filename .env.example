# ==================== DOCKER ====================
# Database
POSTGRES_USER=aqlli_user
POSTGRES_PASSWORD=aqlli_pass
POSTGRES_DB=aqlli_dala
DB_PORT=5432

# Backend
BACKEND_PORT=8000
PORT=8000
HOST=0.0.0.0

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ==================== TELEGRAM ====================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# ==================== DATABASE ====================
DATABASE_URL=postgresql://aqlli_user:aqlli_pass@db/aqlli_dala
DB_POOL_SIZE=10

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== RATE LIMITING ====================
RATE_LIMIT_PER_MINUTE=5
RATE_LIMIT_ENABLED=true

# ==================== ALERTS ====================
MOISTURE_THRESHOLD=25
ALERT_CHECK_INTERVAL=300

# ==================== LOGGING ====================
LOG_LEVEL=INFO

# ==================== SECURITY ====================
JWT_SECRET_KEY=change-this-to-a-random-secret-key-min-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==================== PHONE VALIDATION ====================
PHONE_PATTERN=^\+998\d{9}$

# ==================== RETRY ====================
TELEGRAM_RETRY_ATTEMPTS=3
TELEGRAM_RETRY_DELAY=5

# ==================== FILE UPLOADS ====================
MAX_UPLOAD_SIZE_MB=10
MEDIA_DIR=media

# ==================== ENVIRONMENT ====================
ENVIRONMENT=development
