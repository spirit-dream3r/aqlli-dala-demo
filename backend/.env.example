# ==================== TELEGRAM ====================
# Получить токен бота: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=1234567890:AABBccDDeeFFggHHiiJJkkLLmmNNooP

# Chat ID канала/группы для уведомлений (начинается с -100)
# Узнать через @getmyid_bot
TELEGRAM_CHAT_ID=-1001234567890

# Секретный токен для проверки webhook (придумайте свой)
TELEGRAM_WEBHOOK_SECRET=your_super_secret_webhook_token_123

# ==================== DATABASE ====================
# SQLite (для разработки)
DATABASE_URL=sqlite:///./aqlli_dala.db

# PostgreSQL (для production)
# DATABASE_URL=postgresql://aqlli_user:aqlli_pass@localhost:5432/aqlli_dala

# Размер пула подключений (1-50)
DB_POOL_SIZE=10

# ==================== SERVER ====================
HOST=0.0.0.0
PORT=8000

# ==================== CORS ====================
# Разрешенные origins (через запятую)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3003

# ==================== RATE LIMITING ====================
# Лимит запросов в минуту на /api/lead
RATE_LIMIT_PER_MINUTE=5
RATE_LIMIT_ENABLED=true

# ==================== ALERTS ====================
# Порог влажности для тревоги (%)
MOISTURE_THRESHOLD=25

# Интервал проверки тревог (секунды)
ALERT_CHECK_INTERVAL=300

# ==================== LOGGING ====================
# Уровни: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== SECURITY ====================
# Смените на случайную строку 32+ символов для production!
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==================== PHONE VALIDATION ====================
# Паттерн для телефонов Узбекистана
PHONE_PATTERN=^\+998\d{9}$

# ==================== RETRY ====================
# Количество попыток отправки в Telegram
TELEGRAM_RETRY_ATTEMPTS=3

# Задержка между попытками (секунды)
TELEGRAM_RETRY_DELAY=5

# ==================== FILE UPLOADS ====================
# Максимальный размер файлов (MB)
MAX_UPLOAD_SIZE_MB=10

# Директория для медиафайлов
MEDIA_DIR=media

# ==================== ENVIRONMENT ====================
# Окружение: development, production, testing
ENVIRONMENT=development

# ==================== WEATHER API ====================
# Получить API ключ: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# ==================== SMS API (CLICK.UZ) ====================
# Получить API ключ: https://click.uz
CLICK_API_KEY=your_click_api_key_here
CLICK_API_SECRET=your_click_api_secret_here
